# ================================================================
# .env.example — Copy this file to .env and fill in your keys
# ================================================================
# HOW TO USE:
#   cp .env.example .env
# Then open .env and replace placeholder values with real keys
# ================================================================

# ---------------------------------------------------------------
# LLM — Pick ONE. Groq is free, no credit card needed.
# Groq:     console.groq.com
# OpenAI:   platform.openai.com
# ---------------------------------------------------------------
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-key-here
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
LLM_MODEL=llama3-8b-8192
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ---------------------------------------------------------------
# WEB SEARCH — Tavily free tier, 1000 calls/month
# Sign up at: app.tavily.com
# ---------------------------------------------------------------
TAVILY_API_KEY=your-tavily-key-here

# ---------------------------------------------------------------
# EMBEDDINGS — BGE runs locally, completely free
# ---------------------------------------------------------------
EMBEDDING_PROVIDER=bge
EMBEDDING_MODEL_BGE=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=64

# ---------------------------------------------------------------
# VECTOR DATABASE
# faiss = built-in, no external service needed (default)
# chroma = local persistence, no Docker needed
# ---------------------------------------------------------------
VECTOR_STORE_PROVIDER=faiss

# ---------------------------------------------------------------
# CHUNKING
# Options: semantic | fixed | hierarchical | sentence
#          propositional | table_aware | structure
# ---------------------------------------------------------------
CHUNKING_STRATEGY=semantic
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ---------------------------------------------------------------
# RETRIEVAL
# ---------------------------------------------------------------
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
ENABLE_RERANKING=true
HYBRID_ALPHA=0.7
ENABLE_QUERY_EXPANSION=false
MAX_EXPANDED_QUERIES=3

# ---------------------------------------------------------------
# GENERATION STRATEGY
# Options: basic | self_rag | flare | agentic
# ---------------------------------------------------------------
GENERATION_STRATEGY=basic

# ---------------------------------------------------------------
# REDIS PASSWORD (docker-compose deployments only)
# Required when running the stack via docker-compose.yml. The compose
# file falls back to CHANGE_ME_IN_PROD if this is unset — that is
# intentional: the stack will start but ships a known credential.
# Set a real password here before running docker compose up.
# Local dev without Docker can leave this blank.
# ---------------------------------------------------------------
REDIS_PASSWORD=your-redis-password-here

# ---------------------------------------------------------------
# CACHE
# ---------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_QUERY=3600
CACHE_TTL_EMBEDDING=86400

# ---------------------------------------------------------------
# BACKGROUND TASKS
# ---------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
INGESTION_CONCURRENCY=4

# ---------------------------------------------------------------
# GRAFANA ADMIN PASSWORD (docker-compose deployments only)
# Required when running Grafana via docker-compose.yml. The compose
# file falls back to CHANGE_ME_IN_PROD if this is unset — that is
# intentional: set a real password here before running docker compose up.
# ---------------------------------------------------------------
GF_ADMIN_PASSWORD=your-grafana-admin-password-here

# ---------------------------------------------------------------
# MONITORING — Optional, leave empty to skip
# Free account at: cloud.langfuse.com
# ---------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
ENABLE_TRACING=false

# ---------------------------------------------------------------
# EVALUATION — Optional, for quality metrics
# Requires RAGAS: pip install ragas
# ---------------------------------------------------------------
ENABLE_EVALUATION=false
EVAL_STRATEGY=heuristic
RAGAS_ENABLED=false

# ---------------------------------------------------------------
# APP
# ---------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true

# ---------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins for cross-origin requests.
# Default is localhost:8501 (Streamlit dev port).
# For production deploys, set to your frontend's URL:
#   CORS_ORIGINS=https://ragcore.streamlit.app
# ---------------------------------------------------------------
CORS_ORIGINS=http://localhost:8501

# === API Key Authentication ===
# When auth_enabled=true, all non-exempt endpoints require the X-API-Key
# header. Exempt paths: /health, /health/live, /health/ready, /metrics.
# Default: disabled, so the Streamlit demo works without keys.
RAGCORE_AUTH_ENABLED=false
# Required only when RAGCORE_AUTH_ENABLED=true. Use a long random value
# (e.g., python -c 'import secrets; print(secrets.token_urlsafe(32))').
RAGCORE_API_KEY=
